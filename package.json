{
  "name": "create-kdna-web-app",
  "version": "0.3.1",
  "description": "Scaffold a KDNA-integrated web application with Next.js App Router, Next.js Pages Router, or Express templates.",
  "type": "commonjs",
  "bin": {
    "create-kdna-web-app": "bin/create-kdna-web-app.js"
  },
  "files": [
    "bin/",
    "docs/",
    "src/",
    "templates/",
    "LICENSE",
    "NOTICE",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "ci": "npm test && npm run test:templates && npm run lint && npm pack --dry-run --json",
    "test": "node --test tests/scaffold.test.js",
    "test:templates": "node scripts/test-templates.js",
    "lint": "node scripts/lint.js",
    "prepublishOnly": "npm run ci"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/create-kdna-web-app.git"
  },
  "bugs": {
    "url": "https://github.com/aikdna/create-kdna-web-app/issues"
  },
  "homepage": "https://github.com/aikdna/create-kdna-web-app",
  "keywords": [
    "kdna",
    "create-kdna-web-app",
    "scaffold",
    "nextjs",
    "express",
    "judgment-asset",
    "starter"
  ]
}
